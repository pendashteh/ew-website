---
layout: base.njk
---

{#──────────────────────────────────────────────────────────────────────────
  MACROS
──────────────────────────────────────────────────────────────────────────#}

{% macro activityStatusBadge(status) -%}
  {%- if status == "in_planning" -%}<span class="badge text-bg-warning text-dark">In planning</span>
  {%- elif status == "upcoming" -%}<span class="badge text-bg-success">Upcoming</span>
  {%- elif status == "happening" -%}<span class="badge text-bg-primary">Happening now</span>
  {%- elif status == "past" -%}<span class="badge text-bg-secondary">Past</span>
  {%- endif -%}
{%- endmacro %}

{% macro activityCard(activity) %}
<div class="activity-item p-3 mb-2 rounded-3 bg-body-secondary" data-source="{{ activity.source or 'community' }}">
  <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
    <span class="fw-semibold small">{{ activity.title }}</span>
    <div class="d-flex gap-1 flex-shrink-0 flex-wrap justify-content-end">
      <span class="badge border text-secondary" style="font-size: 0.65rem">
        {%- if activity.source == "official" -%}Official{%- else -%}Community{%- endif -%}
      </span>
      {{ activityStatusBadge(activity.status) }}
    </div>
  </div>
  {% if activity.date %}
  <p class="small text-secondary mb-1"><i class="bi bi-calendar3 me-1"></i>{{ activity.date }}</p>
  {% endif %}
  {% if activity.description %}
  <p class="small mb-1">{{ activity.description }}</p>
  {% endif %}
  {% if activity.link %}
  <a href="{{ activity.link }}" class="small text-decoration-none" target="_blank" rel="noopener">
    <i class="bi bi-box-arrow-up-right me-1"></i>{{ activity.link_label if activity.link_label else "More info" }}
  </a>
  {% endif %}
</div>
{% endmacro %}

{% macro phaseBlock(icon, label, items) %}
{% if items and items.length %}
<div class="mt-3">
  <p class="text-uppercase text-secondary mb-2" style="font-size: 0.68rem; letter-spacing: 0.08em; font-weight: 600">
    <i class="bi {{ icon }} me-1"></i>{{ label }}
  </p>
  {% for activity in items %}{{ activityCard(activity) }}{% endfor %}
</div>
{% endif %}
{% endmacro %}

{% macro editionActivities(edition) %}
{% if edition.activities %}
  {{ phaseBlock("bi-arrow-left-circle", "Before", edition.activities.before) }}
  {{ phaseBlock("bi-broadcast", "During", edition.activities.during) }}
  {{ phaseBlock("bi-arrow-right-circle", "After", edition.activities.after) }}
{% endif %}
{% endmacro %}

{% macro cfpBlock(cfp) %}
{% if cfp and cfp.status == "open" %}
<div class="alert alert-success py-2 px-3 small mb-0 mt-2 border-0 rounded-2">
  <i class="bi bi-megaphone me-1"></i>
  <strong>Call for Papers is open</strong>
  {%- if cfp.deadline %} — closes {{ cfp.deadline }}{% endif %}
  {%- if cfp.url %} · <a href="{{ cfp.url }}" target="_blank" rel="noopener" class="alert-link">Submit a proposal</a>{% endif %}
</div>
{% elif cfp and cfp.status == "closed" %}
<p class="small text-secondary mb-0 mt-1"><i class="bi bi-megaphone me-1"></i>CFP closed</p>
{% endif %}
{% endmacro %}

{% macro editionStatusBadge(status) -%}
  {%- if status == "upcoming" -%}<span class="badge text-bg-primary">Upcoming</span>
  {%- elif status == "happening" -%}<span class="badge text-bg-success">Happening now</span>
  {%- elif status == "past" -%}<span class="badge text-bg-secondary">Past</span>
  {%- endif -%}
{%- endmacro %}


{#──────────────────────────────────────────────────────────────────────────
  PAGE HEADER
──────────────────────────────────────────────────────────────────────────#}

<div class="mb-3">
  <a href="/chainference/" class="text-secondary text-decoration-none small">
    <i class="bi bi-arrow-left me-1"></i>All chainferences
  </a>
</div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div class="d-flex align-items-center gap-3">
    {% if conference.logo %}
    <img src="{{ conference.logo }}" alt="{{ conference.name }} logo" style="height: 48px; width: auto">
    {% endif %}
    <div>
      <h1 class="h2 mb-0">{{ conference.name }} Chainference</h1>
      <p class="text-secondary mb-0 small">{{ conference.tagline }}</p>
    </div>
  </div>
  <a href="{{ conference.url }}" class="btn btn-outline-secondary btn-sm flex-shrink-0" target="_blank" rel="noopener">
    <i class="bi bi-box-arrow-up-right me-1"></i>Official site
  </a>
</div>

{% if content and content | trim %}
<div class="mb-4">{{ content | safe }}</div>
{% endif %}


{#──────────────────────────────────────────────────────────────────────────
  "YOU ARE HERE" CONTEXT STRIP
──────────────────────────────────────────────────────────────────────────#}

{% set currentEdition = null %}
{% for edition in editions %}
  {% if not currentEdition and (edition.status == "upcoming" or edition.status == "happening") %}
    {% set currentEdition = edition %}
  {% endif %}
{% endfor %}

{% if currentEdition %}
<div class="alert alert-primary d-flex gap-3 align-items-start mb-4 border-0 rounded-3" role="note">
  <i class="bi bi-geo-alt-fill fs-5 mt-1 flex-shrink-0"></i>
  <div>
    <strong>{{ conference.name }} {{ currentEdition.year }}</strong>
    {% if currentEdition.status == "happening" %} is happening now{% else %} is coming up{% endif %}
    {% if currentEdition.location %} in <strong>{{ currentEdition.location }}</strong>{% endif %}
    {% if currentEdition.format %} · {{ currentEdition.format }}{% endif %}
    {% if currentEdition.dates %} · {{ currentEdition.dates }}{% endif %}
    {% if currentEdition.cfp and currentEdition.cfp.status == "open" %}
    <br><i class="bi bi-megaphone me-1"></i>
    <strong>Call for Papers is open</strong>{% if currentEdition.cfp.deadline %} — closes {{ currentEdition.cfp.deadline }}{% endif %}
    {% if currentEdition.cfp.url %} · <a href="{{ currentEdition.cfp.url }}" target="_blank" rel="noopener" class="alert-link">Submit a proposal</a>{% endif %}
    {% endif %}
  </div>
</div>
{% endif %}


{#──────────────────────────────────────────────────────────────────────────
  VIEW + FILTER TOOLBAR
──────────────────────────────────────────────────────────────────────────#}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div class="btn-group btn-group-sm" role="group" aria-label="View">
    <button type="button" class="btn btn-primary" data-chainference-view="edition">
      <i class="bi bi-stack me-1"></i>By edition
    </button>
    <button type="button" class="btn btn-outline-primary" data-chainference-view="location">
      <i class="bi bi-geo-alt me-1"></i>By location
    </button>
    <button type="button" class="btn btn-outline-primary" data-chainference-view="timeline">
      <i class="bi bi-calendar3 me-1"></i>Timeline
    </button>
  </div>
  <div class="btn-group btn-group-sm" role="group" aria-label="Filter">
    <button type="button" class="btn btn-secondary active" data-chainference-filter="all">All</button>
    <button type="button" class="btn btn-outline-secondary" data-chainference-filter="official">Official</button>
    <button type="button" class="btn btn-outline-secondary" data-chainference-filter="community">Community</button>
  </div>
</div>


{#──────────────────────────────────────────────────────────────────────────
  VIEW: BY EDITION (default)
──────────────────────────────────────────────────────────────────────────#}

<div id="view-edition">
  {% for edition in editions %}
  <div class="card mb-4 border-0 shadow-sm"
       style="border-left: 4px solid {{ 'var(--bs-primary)' if (edition.status == 'upcoming' or edition.status == 'happening') else 'var(--bs-secondary-bg)' }} !important">
    <div class="card-body">
      <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-1">
        <div>
          <h2 class="h5 mb-0">
            {{ conference.name }} {{ edition.year }}
            {% if edition.location %}<span class="fw-normal text-secondary"> · {{ edition.location }}</span>{% endif %}
          </h2>
          <p class="small text-secondary mb-0">
            {{ edition.format }}{% if edition.dates %} · {{ edition.dates }}{% endif %}
          </p>
        </div>
        <div class="d-flex gap-2 align-items-center">
          {% if edition.url %}
          <a href="{{ edition.url }}" class="text-secondary small text-decoration-none" target="_blank" rel="noopener" title="Official site">
            <i class="bi bi-box-arrow-up-right"></i>
          </a>
          {% endif %}
          {{ editionStatusBadge(edition.status) }}
        </div>
      </div>
      {{ cfpBlock(edition.cfp) }}
      {{ editionActivities(edition) }}
    </div>
  </div>
  {% endfor %}
</div>


{#──────────────────────────────────────────────────────────────────────────
  VIEW: BY LOCATION
──────────────────────────────────────────────────────────────────────────#}

<div id="view-location" class="d-none">
  {% for group in editions | groupBy("location") %}
  <div class="mb-5">
    <h2 class="h5 d-flex align-items-center gap-2 mb-3 border-bottom pb-2">
      <i class="bi bi-geo-alt-fill text-primary"></i>{{ group.key }}
    </h2>
    {% for edition in group.items %}
    <div class="card mb-3 border-0 bg-body-secondary">
      <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-1">
          <div>
            <h3 class="h6 mb-0">
              {{ conference.name }} {{ edition.year }}
            </h3>
            <p class="small text-secondary mb-0">{{ edition.format }}{% if edition.dates %} · {{ edition.dates }}{% endif %}</p>
          </div>
          <div class="d-flex gap-2 align-items-center">
            {% if edition.url %}
            <a href="{{ edition.url }}" class="text-secondary small text-decoration-none" target="_blank" rel="noopener" title="Official site">
              <i class="bi bi-box-arrow-up-right"></i>
            </a>
            {% endif %}
            {{ editionStatusBadge(edition.status) }}
          </div>
        </div>
        {{ cfpBlock(edition.cfp) }}
        {{ editionActivities(edition) }}
      </div>
    </div>
    {% endfor %}
  </div>
  {% endfor %}
</div>


{#──────────────────────────────────────────────────────────────────────────
  VIEW: TIMELINE
──────────────────────────────────────────────────────────────────────────#}

<div id="view-timeline" class="d-none">

  {# Upcoming / happening editions first #}
  {% for edition in editions %}
  {% if edition.status == "upcoming" or edition.status == "happening" %}
  <div class="d-flex gap-0 mb-0">
    <div class="d-flex flex-column align-items-center flex-shrink-0" style="width: 48px">
      <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold bg-primary flex-shrink-0"
           style="width: 44px; height: 44px; font-size: 0.68rem">{{ edition.year }}</div>
      <div style="width: 2px; flex-grow: 1; min-height: 16px; background: var(--bs-border-color)"></div>
    </div>
    <div class="flex-grow-1 ps-3 pb-4">
      <div class="d-flex flex-wrap justify-content-between align-items-start gap-1 mb-1">
        <div>
          <span class="fw-semibold">{{ conference.name }} {{ edition.year }}</span>
          {% if edition.location %}<span class="text-secondary"> · {{ edition.location }}</span>{% endif %}
          <br><small class="text-secondary">{{ edition.format }}{% if edition.dates %} · {{ edition.dates }}{% endif %}</small>
        </div>
        <div class="d-flex gap-1 align-items-center">
          {% if edition.url %}
          <a href="{{ edition.url }}" class="text-secondary small text-decoration-none" target="_blank" rel="noopener"><i class="bi bi-box-arrow-up-right"></i></a>
          {% endif %}
          {{ editionStatusBadge(edition.status) }}
        </div>
      </div>
      {{ cfpBlock(edition.cfp) }}
      {{ editionActivities(edition) }}
    </div>
  </div>
  {% endif %}
  {% endfor %}

  {# NOW divider #}
  <div class="d-flex align-items-center gap-0 my-2" aria-hidden="true">
    <div class="d-flex justify-content-center flex-shrink-0" style="width: 48px">
      <span class="badge text-bg-danger px-2" style="font-size: 0.65rem; letter-spacing: 0.05em">NOW</span>
    </div>
    <div class="flex-grow-1 ms-3" style="height: 2px; background: var(--bs-danger); opacity: 0.35"></div>
  </div>

  {# Past editions #}
  {% for edition in editions %}
  {% if edition.status == "past" %}
  <div class="d-flex gap-0 mb-0">
    <div class="d-flex flex-column align-items-center flex-shrink-0" style="width: 48px">
      <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold bg-secondary flex-shrink-0"
           style="width: 44px; height: 44px; font-size: 0.68rem">{{ edition.year }}</div>
      <div style="width: 2px; flex-grow: 1; min-height: 16px; background: var(--bs-border-color)"></div>
    </div>
    <div class="flex-grow-1 ps-3 pb-4">
      <div class="d-flex flex-wrap justify-content-between align-items-start gap-1 mb-1">
        <div>
          <span class="fw-semibold">{{ conference.name }} {{ edition.year }}</span>
          {% if edition.location %}<span class="text-secondary"> · {{ edition.location }}</span>{% endif %}
          <br><small class="text-secondary">{{ edition.format }}{% if edition.dates %} · {{ edition.dates }}{% endif %}</small>
        </div>
        <div class="d-flex gap-1 align-items-center">
          {% if edition.url %}
          <a href="{{ edition.url }}" class="text-secondary small text-decoration-none" target="_blank" rel="noopener"><i class="bi bi-box-arrow-up-right"></i></a>
          {% endif %}
          {{ editionStatusBadge(edition.status) }}
        </div>
      </div>
      {{ cfpBlock(edition.cfp) }}
      {{ editionActivities(edition) }}
    </div>
  </div>
  {% endif %}
  {% endfor %}

</div>


{#──────────────────────────────────────────────────────────────────────────
  PROPOSE AN ACTIVITY CTA
──────────────────────────────────────────────────────────────────────────#}

<div class="p-4 border border-primary border-opacity-25 rounded-3 text-center mt-4">
  <h3 class="h6 mb-2">Organising something around {{ conference.name }}?</h3>
  <p class="small text-secondary mb-3">Submit workshops, meetups, watch parties, ideation sessions — anything that helps the community engage with this conference.</p>
  <a href="https://github.com/electron-workshop/ew-website/issues/new?template=chainference-activity.yml" class="btn btn-outline-primary btn-sm">
    <i class="bi bi-plus-circle me-1"></i>Propose an activity
  </a>
</div>


{#──────────────────────────────────────────────────────────────────────────
  INLINE JS — view switching + activity filter
──────────────────────────────────────────────────────────────────────────#}

<script>
(function () {
  const VIEWS = ['edition', 'location', 'timeline'];
  let activeFilter = 'all';

  function applyFilter(filter) {
    activeFilter = filter;
    document.querySelectorAll('.activity-item').forEach(function (el) {
      const match = filter === 'all' || el.dataset.source === filter;
      el.classList.toggle('d-none', !match);
    });
  }

  // View buttons
  document.querySelectorAll('[data-chainference-view]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      const view = btn.getAttribute('data-chainference-view');
      VIEWS.forEach(function (v) {
        var el = document.getElementById('view-' + v);
        if (el) el.classList.toggle('d-none', v !== view);
      });
      document.querySelectorAll('[data-chainference-view]').forEach(function (b) {
        const isActive = b.getAttribute('data-chainference-view') === view;
        b.classList.toggle('btn-primary', isActive);
        b.classList.toggle('btn-outline-primary', !isActive);
      });
      applyFilter(activeFilter);
    });
  });

  // Filter buttons
  document.querySelectorAll('[data-chainference-filter]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      const filter = btn.getAttribute('data-chainference-filter');
      applyFilter(filter);
      document.querySelectorAll('[data-chainference-filter]').forEach(function (b) {
        const isActive = b.getAttribute('data-chainference-filter') === filter;
        b.classList.toggle('active', isActive);
        b.classList.toggle('btn-secondary', isActive);
        b.classList.toggle('btn-outline-secondary', !isActive);
      });
    });
  });
}());
</script>
